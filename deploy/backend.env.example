# Production backend environment for EC2.
# Copy this to backend/.env on the server and fill in real values.
# NEVER commit the filled-in file (backend/.env is gitignored).

# --- Database (RDS PostgreSQL) ---
# Use the RDS endpoint. Keep sslmode=require for encrypted connections.
DATABASE_URL="postgresql://posadmin:CHANGE_ME_STRONG_PASSWORD@your-rds-endpoint.eu-north-1.rds.amazonaws.com:5432/restaurant_pos?schema=public&sslmode=require"

# --- JWT secrets ---
# Generate each with:  openssl rand -base64 48
JWT_ACCESS_SECRET="CHANGE_ME_generate_with_openssl_rand"
JWT_REFRESH_SECRET="CHANGE_ME_generate_with_openssl_rand_different"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# --- App ---
APP_PORT=4000
APP_URL="https://api.yourdomain.com"

# CORS allow-list. Set to your Amplify domain(s), comma-separated.
# e.g. the default Amplify URL plus your custom domain:
FRONTEND_URL="https://main.xxxxxxxx.amplifyapp.com,https://pos.yourdomain.com"

# --- Uploads (local disk on the EC2 EBS volume) ---
UPLOAD_DIR="./uploads"
