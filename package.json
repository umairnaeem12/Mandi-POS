{
  "name": "restaurant-pos",
  "version": "0.1.0",
  "private": true,
  "description": "Restaurant POS System - multi-user point-of-sale (NestJS + React + Tauri)",
  "workspaces": [
    "backend",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:web": "npm run dev --workspace pos-web",
    "build:backend": "npm run build --workspace backend",
    "build:web": "npm run build --workspace pos-web",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
